{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Study Atlas default capabilities",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-close",
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-copy-file",
    "store:default",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "shell:default"
  ]
}